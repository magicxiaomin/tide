.catch-card {
  min-height: 100vh;
  padding: 48rpx 28rpx 56rpx;
  background:
    radial-gradient(circle at 18% 8%, rgba(242, 197, 124, 0.35), transparent 30%),
    linear-gradient(180deg, #082f42 0%, #eaf5f8 52%, #f7efe0 100%);
}

.hero {
  color: #ffffff;
  margin-bottom: 28rpx;
}

.eyebrow {
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  letter-spacing: 4rpx;
}

.title {
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 900;
}

.subtitle,
.hint,
.status,
.empty {
  font-size: 24rpx;
}

.subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
}

.canvas-wrap {
  overflow: hidden;
  border-radius: 36rpx;
  box-shadow: 0 28rpx 70rpx rgba(4, 29, 42, 0.22);
  background: #073b4c;
}

.card-canvas {
  display: block;
  width: 100%;
}

.privacy-panel {
  display: grid;
  gap: 14rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.86);
}

.panel-title {
  color: #073b4c;
  font-size: 28rpx;
  font-weight: 900;
}

.privacy-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #34535f;
  font-size: 26rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.actions button,
.empty button,
.status button {
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #073b4c;
  font-weight: 800;
}

.actions .primary {
  background: #f2c57c;
  color: #102033;
}

.hint {
  margin-top: 20rpx;
  color: #526a74;
  text-align: center;
}

.status,
.empty {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #073b4c;
  text-align: center;
}

.status.warn {
  color: #8a4b00;
  background: #fff1d6;
}

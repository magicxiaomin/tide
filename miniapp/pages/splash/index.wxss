.splash {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
  padding: 96rpx 40rpx 56rpx;
  background:
    linear-gradient(180deg, rgba(5, 43, 64, 0.08), rgba(13, 111, 127, 0.2)),
    linear-gradient(160deg, #052b40 0%, #0f6f7f 48%, #d8f0ef 100%);
}

.sea-mark {
  position: absolute;
  right: -120rpx;
  bottom: 260rpx;
  width: 520rpx;
  height: 520rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.sea-mark::after {
  position: absolute;
  right: 92rpx;
  bottom: 92rpx;
  width: 300rpx;
  height: 300rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  content: "";
}

.brand {
  position: relative;
  z-index: 1;
  color: #ffffff;
}

.logo {
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1.15;
}

.tagline {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  letter-spacing: 0;
}

.status-card {
  position: relative;
  z-index: 1;
  min-height: 320rpx;
  padding: 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 28rpx 70rpx rgba(4, 38, 56, 0.18);
}

.loader {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 28rpx;
  border: 5rpx solid rgba(15, 111, 127, 0.18);
  border-top-color: #0f6f7f;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.status-title {
  color: #102033;
  font-size: 34rpx;
  font-weight: 800;
}

.status-copy,
.field-label,
.timestamp {
  margin-top: 18rpx;
  color: #5e7580;
  font-size: 24rpx;
}

.hello {
  margin-top: 10rpx;
  color: #0f6f7f;
  font-size: 40rpx;
  font-weight: 800;
}

.openid {
  margin-top: 10rpx;
  padding: 18rpx;
  border-radius: 10rpx;
  background: #eef7f8;
  color: #102033;
  font-family: "SFMono-Regular", Consolas, monospace;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.error {
  margin-top: 18rpx;
  color: #a13d24;
  font-size: 24rpx;
  line-height: 1.5;
}

.retry-button,
.home-button {
  margin: 28rpx 0 0;
  border-radius: 12rpx;
  background: #0f6f7f;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.home-button {
  width: 100%;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

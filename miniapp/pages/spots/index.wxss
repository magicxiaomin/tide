.spots {
  min-height: 100vh;
  padding: 64rpx 32rpx 48rpx;
  background: #eaf5f8;
}

.header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.header button {
  margin: 0;
  border-radius: 10rpx;
  background: #0f6f7f;
  color: #ffffff;
  font-size: 24rpx;
}

.eyebrow,
.spot-meta,
.spot-last,
.current,
.loading,
.error {
  color: #5e7580;
  font-size: 24rpx;
}

.title {
  margin-top: 8rpx;
  color: #102033;
  font-size: 40rpx;
  font-weight: 800;
}

.spot-list {
  display: grid;
  gap: 18rpx;
  margin-top: 32rpx;
}

.spot-card {
  position: relative;
  padding: 28rpx;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  background: #ffffff;
}

.spot-card.active {
  border-color: #0f6f7f;
}

.spot-name {
  color: #102033;
  font-size: 30rpx;
  font-weight: 800;
}

.spot-meta,
.spot-last {
  margin-top: 12rpx;
}

.current {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  color: #0f6f7f;
}

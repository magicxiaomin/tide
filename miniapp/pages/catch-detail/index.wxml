<view class="screen catch-detail">
  <view class="empty" wx:if="{{!hasRecord}}">
    <view>没有找到这条渔获记录</view>
  </view>

  <block wx:else>
    <view class="hero">
      <view class="eyebrow">渔获详情</view>
      <view class="title">{{detail.title}}</view>
      <view class="subtitle">{{detail.speciesText}}</view>
    </view>

    <view class="photos" wx:if="{{detail.photos.length > 0}}">
      <image wx:for="{{detail.photos}}" wx:key="*this" src="{{item}}" mode="aspectFill"></image>
    </view>

    <view class="rows">
      <view class="row" wx:for="{{detail.rows}}" wx:key="label">
        <text>{{item.label}}</text>
        <view>{{item.value}}</view>
      </view>
    </view>

    <button class="primary" bindtap="openCatchCard">生成这条的渔获卡</button>
  </block>
</view>

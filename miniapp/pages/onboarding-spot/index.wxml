<view class="screen spot-select">
  <view class="title">选择常去的钓点</view>
  <view class="copy">先选一个钓点，后面可以随时在「钓点」里切换或添加。</view>

  <view class="loading" wx:if="{{loading}}">正在查找附近钓点</view>
  <view class="error" wx:elif="{{errorMessage}}">{{errorMessage}}</view>

  <view class="spot-list" wx:else>
    <view class="spot-card {{item.is_active ? 'active' : ''}}" wx:for="{{spots}}" wx:key="id" data-id="{{item.id}}" bindtap="selectSpot">
      <view class="spot-name">{{item.name}}</view>
      <view class="spot-meta">{{item.distance_text}} · {{item.fishing_style}}</view>
      <view class="current" wx:if="{{item.is_active}}">当前选择</view>
    </view>
  </view>

  <button class="primary" bindtap="complete">完成,开始使用</button>
</view>

.curve-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(16, 32, 51, 0.07);
}

.curve-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.curve-title {
  color: #102033;
  font-size: 28rpx;
  font-weight: 800;
}

.curve-caption,
.extremes {
  color: #5e7580;
  font-size: 22rpx;
}

.curve-image {
  display: block;
  width: 100%;
  margin-top: 18rpx;
}

.extremes {
  margin-top: 16rpx;
  line-height: 1.45;
}
